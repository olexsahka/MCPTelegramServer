# Copy to .env and fill in real values before deploying
# NEVER commit .env to git

# PostgreSQL
POSTGRES_USER=postgres
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# Redis
REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD

# Telegram credentials (from my.telegram.org)
TELEGRAM_API_ID=your_api_id_from_my.telegram.org
TELEGRAM_API_HASH=your_api_hash_from_my.telegram.org
TELEGRAM_PHONE=+7XXXXXXXXXX

# MCP server credentials (used for HTTP Basic Auth on /mcp endpoint)
MCP_USERNAME=mcp
MCP_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# Admin UI credentials (/admin endpoint)
MCP_ADMIN_USERNAME=admin
MCP_ADMIN_PASSWORD=CHANGE_ME_STRONG_PASSWORD
